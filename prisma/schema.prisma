generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  user
  admin
}

enum EventType {
  view
  click
  impression
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum CategoryType {
  product
  service
}

enum ProductKind {
  service
  physical
}

enum InsightType {
  performance
  timing
  geo
  spend
  opportunity
  alert
}

enum ListingType {
  retail
  wholesale
  b2b
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model User {
  id         String      @id @default(uuid()) @db.Uuid
  name       String
  email      String      @unique
  password   String
  role       Role        @default(user)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  credits    Int         @default(0)

  ads              Ad[]
  reviews          Review[]
  payments         Payment[]
  analytics        Analytics[]
  bannerAds        BannerAd[]
  spendScore       SpendScore?
  savedSearches    SavedSearch[]
  pushSubscriptions PushSubscription[]
  referralCode     ReferralCode?
  referredByUsage  ReferralUsage?     @relation("ReferredByUsage")
}

model Category {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique @db.VarChar(100)
  slug        String       @unique
  type        CategoryType
  description String?      @db.VarChar(500)
  isActive    Boolean      @default(true)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ads          Ad[]
  savedSearches SavedSearch[]

  @@index([slug])
  @@index([type])
  @@index([isActive])
  @@index([order])
}

model Industry {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ads Ad[]

  @@index([slug])
  @@index([isActive])
  @@index([order])
}

model ProductType {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique @db.VarChar(100)
  slug        String      @unique
  type        ProductKind
  description String?     @db.VarChar(500)
  isActive    Boolean     @default(true)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([slug])
  @@index([type])
  @@index([isActive])
  @@index([order])
}

model Ad {
  id            String    @id @default(uuid()) @db.Uuid
  title         String    @db.VarChar(100)
  description   String    @db.VarChar(500)
  imageUrl      String
  webLink       String
  ownerName     String
  location      String
  companyName   String
  countries     String[]
  categoryId    String    @db.Uuid
  industryId    String    @db.Uuid
  userId        String    @db.Uuid
  isActive      Boolean   @default(true)
  isPaid        Boolean   @default(false)
  paymentDate   DateTime?
  expiryDate    DateTime
  topLensExpiry DateTime?
  storiesExpiry DateTime?
  yubboxCount   Int         @default(0)
  listingType   ListingType @default(retail)
  // Visibility score — recomputed by the Auto-Visibility algorithm
  visibilityScore Int       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime  @updatedAt

  user     User     @relation(fields: [userId],     references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  industry Industry @relation(fields: [industryId], references: [id])

  reviews    Review[]
  payments   Payment[]
  analytics  Analytics[]
  insights   AdInsight[]

  @@index([userId])
  @@index([isActive])
  @@index([isPaid])
  @@index([expiryDate])
  @@index([categoryId])
  @@index([industryId])
  @@index([topLensExpiry])
  @@index([storiesExpiry])
  @@index([yubboxCount(sort: Desc)])
  @@index([visibilityScore(sort: Desc)])
  @@index([listingType])
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Int
  comment   String?  @db.VarChar(500)
  adId      String   @db.Uuid
  userId    String?  @db.Uuid
  userName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ad   Ad    @relation(fields: [adId],   references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([adId])
  @@index([userId])
}

model Analytics {
  id           String    @id @default(uuid()) @db.Uuid
  adId         String    @db.Uuid
  eventType    EventType
  country      String?
  ipAddress    String?
  userAgent    String?
  referrer     String?
  timestamp    DateTime  @default(now())
  userId       String?   @db.Uuid
  // ── Behavioural fields (Yubbox Brain / Click Behaviour algorithm) ──
  sessionId    String?                   // groups events from the same browsing session
  scrollDepth  Int?                      // 0–100 — how far down the ad was scrolled before action
  timeOnAd     Int?                      // seconds spent viewing the ad before click/leave
  clickElement String?                   // 'image' | 'title' | 'cta' | 'description' | 'company'
  deviceType   String?                   // 'mobile' | 'desktop' | 'tablet'
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ad   Ad    @relation(fields: [adId],   references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([adId, eventType])
  @@index([adId, timestamp(sort: Desc)])
  @@index([adId, country])
  @@index([sessionId])
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  adId          String        @db.Uuid
  userId        String        @db.Uuid
  amount        Decimal       @default(1.00) @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        PaymentStatus @default(pending)
  paymentMethod String        @default("manual")
  transactionId String?
  paymentDate   DateTime      @default(now())
  expiryDate    DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  ad   Ad   @relation(fields: [adId],   references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([userId])
  @@index([status])
  @@index([expiryDate])
}

model BannerAd {
  id           String   @id @default(uuid()) @db.Uuid
  title        String   @db.VarChar(100)
  description  String?  @db.VarChar(500)
  imageUrl     String
  linkUrl      String
  cost         Decimal  @db.Decimal(10, 2)
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdById  String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([isActive])
  @@index([startDate, endDate])
  @@index([displayOrder])
}

// ── Yubbox Intelligence — Insight cards generated per ad ──────────────────────
model AdInsight {
  id        String      @id @default(uuid()) @db.Uuid
  adId      String      @db.Uuid
  type      InsightType
  title     String      @db.VarChar(200)
  body      String      @db.VarChar(600)
  impact    String      @db.VarChar(10)   // 'high' | 'medium' | 'low'
  priority  Int         @default(0)       // higher = shown first
  data      Json?                         // structured payload for charts/sparklines
  isRead    Boolean     @default(false)
  expiresAt DateTime
  createdAt DateTime    @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, priority(sort: Desc)])
  @@index([expiresAt])
}

// ── Saved Searches + Push Notifications ──────────────────────────────────────
model SavedSearch {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  label      String?   @db.VarChar(100)
  query      String?   @db.VarChar(200)
  country    String?   @db.VarChar(10)
  categoryId String?   @db.Uuid
  createdAt  DateTime  @default(now())

  user     User      @relation(fields: [userId],     references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  endpoint  String   @unique @db.VarChar(1000)
  p256dh    String   @db.VarChar(200)
  auth      String   @db.VarChar(100)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Referral Programme ────────────────────────────────────────────────────────
model ReferralCode {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid @unique
  code      String          @unique @db.VarChar(20)
  createdAt DateTime        @default(now())

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ReferralUsage[]

  @@index([code])
}

model ReferralUsage {
  id             String   @id @default(uuid()) @db.Uuid
  referralCodeId String   @db.Uuid
  referredUserId String   @db.Uuid @unique
  createdAt      DateTime @default(now())

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id])
  referredUser User         @relation("ReferredByUsage", fields: [referredUserId], references: [id])

  @@index([referralCodeId])
}

// ── Social Links — managed from admin dashboard ───────────────────────────────
model SocialLink {
  id        String   @id @default(uuid()) @db.Uuid
  platform  String   @db.VarChar(50)   // e.g. 'x', 'instagram', 'linkedin', 'facebook'
  label     String   @db.VarChar(50)   // Display name e.g. 'X', 'Instagram'
  url       String   @db.VarChar(500)
  symbol    String   @db.VarChar(20)   // Short glyph e.g. '𝕏', 'IG', 'in', 'f'
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

// ── Password Reset Tokens ─────────────────────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

// ── Yubbox Spend Score — per-user efficiency rating ───────────────────────────
model SpendScore {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @unique
  score           Int      @default(0)     // 0–100
  viewsPerDollar  Decimal  @default(0) @db.Decimal(10, 4)
  clicksPerDollar Decimal  @default(0) @db.Decimal(10, 4)
  engagementRate  Decimal  @default(0) @db.Decimal(10, 4)
  categoryRank    Int      @default(0)     // percentile rank within category (0–100)
  breakdown       Json                     // factor-level breakdown for UI
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
